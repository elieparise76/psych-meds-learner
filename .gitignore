# Dependencies
node_modules/

# OS / editor
.DS_Store
*.swp
.idea/
.vscode/

# Pipeline scratch
pipeline/*.log
*.tmp

# macOS .app build — intermediates + the unzipped bundle are reproducible via app-package/make-app.sh.
# The single sendable artifact, dist/Titrate-macOS.zip, IS committed (see !rule below).
app-package/build/
dist/Titrate.app/
!dist/Titrate-macOS.zip

# Raw API response cache — local-only, regenerated by re-running the pipeline (which hits the
# live APIs). Kept out of git to stay lean; durable provenance lives in data/deck.js citations
# + extracted excerpts. Delete it to force a full re-fetch, or pass --refresh.
data/raw/
